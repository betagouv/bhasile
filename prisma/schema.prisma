generator client {
  provider        = "prisma-client"
  previewFeatures = ["views"]
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "reporting"]
}

model Departement {
  id                      Int                      @id @default(autoincrement())
  numero                  String                   @unique
  name                    String
  region                  String
  structures              Structure[]
  departementAllowedUsers DepartementAllowedUser[]
  regionAdministrative    Region?                  @relation(fields: [regionId], references: [id])
  regionId                Int?
  cpoms                   CpomDepartement[]

  @@schema("public")
}

model Region {
  id           Int           @id @default(autoincrement())
  name         String
  code         String
  departements Departement[]
  cpoms        Cpom[]

  @@schema("public")
}

model Structure {
  id                           Int                         @id @default(autoincrement())
  dnaCode                      String?                      @unique                 
  codeBhasile                  String?                     @unique
  filiale                      String?
  type                         StructureType?
  adresseAdministrative        String?
  codePostalAdministratif      String?
  communeAdministrative        String?
  departementAdministratif     String?
  latitude                     Decimal?
  longitude                    Decimal?
  nom                          String?
  debutConvention              DateTime?
  finConvention                DateTime?
  creationDate                 DateTime?
  date303                      DateTime?
  finessCode                   String? // TODO remove after migration to own table
  lgbt                         Boolean?
  fvvTeh                       Boolean?
  public                       PublicType?
  debutPeriodeAutorisation     DateTime?
  finPeriodeAutorisation       DateTime?
  notes                        String?
  nomOfii                      String?
  directionTerritoriale        String?
  activeInOfiiFileSince        DateTime? // date d'entrée dans le document Ofii
  inactiveInOfiiFileSince      DateTime? // date de sortie du document Ofii
  dnaStructures               DnaStructure[]
  controles                    Controle[]
  evaluations                  Evaluation[]
  evenementsIndesirablesGraves EvenementIndesirableGrave[]
  adresses                     Adresse[]
  contacts                     Contact[]
  structureTypologies          StructureTypologie[]
  activites                    Activite[]
  actesAdministratifs          ActeAdministratif[]
  documentsFinanciers          DocumentFinancier[]
  cpomStructures               CpomStructure[]
  structureMillesimes          StructureMillesime[]
  budgets                      Budget[]
  operateur                    Operateur?                  @relation(fields: [operateurId], references: [id])
  operateurId                  Int?
  forms                        Form[]
  campaigns                    Campaign[]
  antennes                     Antenne[]
  finesses                     Finess[]
  departement                  Departement?                @relation(fields: [departementAdministratif], references: [numero])
  userActions                  UserAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model Dna {
  id                           Int                         @id @default(autoincrement())
  code                         String                      @unique
  description                  String?
  dnaStructures                DnaStructure[]
  activites                    Activite[]
  evenementsIndesirablesGraves EvenementIndesirableGrave[]

  createdAt                    DateTime                    @default(now())
  updatedAt                    DateTime                    @default(now()) @updatedAt

  @@schema("public")
}

model DnaStructure {
  id          Int       @id @default(autoincrement())
  dnaId       Int
  dna         Dna       @relation(fields: [dnaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureId Int
  structure   Structure @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  startDate   DateTime? // Empty by default, set when a DNA changes its structure
  endDate     DateTime? // Empty by default, set when a DNA changes its structure

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  @@schema("public")
}

model Controle {
  id               Int          @id @default(autoincrement())
  structure        Structure?   @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureDnaCode String?      // TODO : à supprimer une fois la migration vers le multi-DNA terminée
  structureId      Int?
  date             DateTime
  type             ControleType
  fileUploads      FileUpload[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model Evaluation {
  id               Int          @id @default(autoincrement())
  structure        Structure?   @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureDnaCode String?      // TODO : à supprimer une fois la migration vers le multi-DNA terminée
  structureId      Int?
  date             DateTime?
  notePersonne     Float?
  notePro          Float?
  noteStructure    Float?
  note             Float?
  fileUploads      FileUpload[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model EvenementIndesirableGrave {
  id               Int        @id @default(autoincrement())
  structure        Structure? @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureDnaCode String?    // TODO : à supprimer une fois la migration vers le multi-DNA terminée
  structureId      Int?
  dnaCode          String?
  dna              Dna?       @relation(fields: [dnaCode], references: [code], onDelete: Cascade, onUpdate: Cascade)
  numeroDossier    String     @unique
  evenementDate    DateTime
  declarationDate  DateTime
  type             String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model Adresse {
  id                Int                @id @default(autoincrement())
  structure         Structure?         @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureDnaCode  String?            // TODO : à supprimer une fois la migration vers le multi-DNA terminée
  structureId       Int?
  adresse           String?
  codePostal        String?
  commune           String?
  repartition       Repartition?
  adresseTypologies AdresseTypologie[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model AdresseTypologie {
  id               Int     @id @default(autoincrement())
  adresse          Adresse @relation(fields: [adresseId], references: [id], onDelete: Cascade)
  adresseId        Int
  placesAutorisees Int
  year             Int
  qpv              Int
  logementSocial   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([adresseId, year])
  @@schema("public")
}

model Contact {
  id               Int        @id @default(autoincrement())
  structure        Structure? @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureDnaCode String?    // TODO : à supprimer une fois la migration vers le multi-DNA terminée
  structureId      Int?
  prenom           String?
  nom              String?
  telephone        String?
  email            String?
  role             String?
  perimetre        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model StructureMillesime {
  id               Int       @id @default(autoincrement())
  structure        Structure?@relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureDnaCode String?             // TODO : à supprimer une fois la migration vers le multi-DNA terminée
  structureId          Int?
  year             Int
  cpom             Boolean   @default(false) // temporary field, while we are not sure of existing cpoms
  operateurComment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([structureId, year])
  @@schema("public")
}

model StructureTypologie {
  id                    Int                 @id @default(autoincrement())
  structure             Structure?          @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureDnaCode      String?             // TODO : à supprimer une fois la migration vers le multi-DNA terminée
  structureId           Int?
  year                  Int
  placesAutorisees      Int?
  pmr                   Int?
  lgbt                  Int?
  fvvTeh                Int?
  placesACreer          Int?
  placesAFermer         Int?
  echeancePlacesACreer  DateTime?
  echeancePlacesAFermer DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([structureId, year])
  @@schema("public")
}

model Activite {
  id                       Int        @id @default(autoincrement())
  structure                Structure? @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureDnaCode         String?    // TODO : à supprimer une fois la migration vers le multi-DNA terminée
  structureId              Int?
  dnaCode                  String?
  dna                      Dna?       @relation(fields: [dnaCode], references: [code], onDelete: Cascade, onUpdate: Cascade)
  date                     DateTime
  placesAutorisees         Int?
  desinsectisation         Int?
  remiseEnEtat             Int?
  sousOccupation           Int?
  placesIndisponibles      Int?
  placesOccupees           Int?
  travaux                  Int?
  placesVacantes           Int?
  presencesInduesBPI       Int?
  presencesInduesDeboutees Int?

  @@unique([structureId, date])
  @@schema("public")
}

model FileUpload {
  id                    Int                    @id @default(autoincrement())
  key                   String                 @unique
  mimeType              String
  fileSize              Int
  originalName          String
  acteAdministratif     ActeAdministratif?    @relation(fields: [acteAdministratifId], references: [id], onDelete: Cascade)
  acteAdministratifId   Int?
  documentFinancier     DocumentFinancier?    @relation(fields: [documentFinancierId], references: [id], onDelete: Cascade)
  documentFinancierId   Int?
  controle              Controle?             @relation(fields: [controleId], references: [id], onDelete: Cascade)
  controleId            Int?
  evaluation            Evaluation?           @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  evaluationId          Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model ActeAdministratif {
  id                  Int                         @id @default(autoincrement())
  structure           Structure?                  @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureDnaCode    String?                     // TODO : à supprimer une fois la migration vers le multi-DNA terminée
  structureId         Int?
  cpom                Cpom?                       @relation(fields: [cpomId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cpomId              Int?
  category            ActeAdministratifCategory?
  date                DateTime?
  startDate           DateTime?
  endDate             DateTime?
  name                String?
  parent              ActeAdministratif?          @relation("ActeAdministratifToActeAdministratif", fields: [parentId], references: [id], onDelete: Cascade)
  parentId            Int?                        
  children            ActeAdministratif[]         @relation("ActeAdministratifToActeAdministratif")
  fileUploads         FileUpload[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model DocumentFinancier {
  id                  Int                           @id @default(autoincrement())
  structure           Structure?                    @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureDnaCode    String?                       // TODO : à supprimer une fois la migration vers le multi-DNA terminée
  structureId         Int?
  category            DocumentFinancierCategory?
  year                Int
  name                String?
  granularity         DocumentFinancierGranularity  @default(STRUCTURE)
  fileUploads         FileUpload[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model Budget {
  id                                Int                 @id @default(autoincrement())
  structure                         Structure?          @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureDnaCode                  String?             // TODO : à supprimer une fois la migration vers le multi-DNA terminée
  structureId                       Int?
  year                              Int                 @default(0)
  ETP                               Float?
  tauxEncadrement                   Float?
  coutJournalier                    Float?
  dotationDemandee                  Float?
  dotationAccordee                  Float?
  totalProduitsProposes             Float?
  totalProduits                     Float?
  totalCharges                      Float?
  totalChargesProposees             Float?
  repriseEtat                       Float?
  excedentRecupere                  Float?
  excedentDeduit                    Float?
  reserveInvestissement             Float?
  chargesNonReconductibles          Float?
  reserveCompensationDeficits       Float?
  reserveCompensationBFR            Float?
  reserveCompensationAmortissements Float?
  fondsDedies                       Float?
  affectationReservesFondsDedies    Float?
  reportANouveau                    Float?
  autre                             Float?
  commentaire                       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([structureId, year])
  @@schema("public")
}

// Formulaires
model FormDefinition {
  id              Int                  @id @default(autoincrement())
  name            String
  version         Int
  slug            String               @unique
  stepsDefinition FormStepDefinition[]

  forms Form[]

  @@schema("public")
}

model FormStepDefinition {
  id               Int    @id @default(autoincrement())
  formDefinitionId Int
  label            String
  slug             String

  formDefinition FormDefinition @relation(fields: [formDefinitionId], references: [id])
  formSteps      FormStep[]

  @@unique([formDefinitionId, slug])
  @@schema("public")
}

model Form {
  id               Int     @id @default(autoincrement())
  structureCodeDna String?     // TODO : à supprimer une fois la migration vers le multi-DNA terminée
  structureId      Int?
  formDefinitionId Int
  status           Boolean @default(false) // Lié au bouton "Finaliser"

  structure      Structure?     @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  formDefinition FormDefinition @relation(fields: [formDefinitionId], references: [id])
  formSteps      FormStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([structureId, formDefinitionId])
  @@schema("public")
}

model FormStep {
  id               Int        @id @default(autoincrement())
  formId           Int
  stepDefinitionId Int
  status           StepStatus @default(NON_COMMENCE)
  // TODO : ajouter le champ authorId en lien avec une table Auteur plus tard

  form           Form               @relation(fields: [formId], references: [id], onDelete: Cascade)
  stepDefinition FormStepDefinition @relation(fields: [stepDefinitionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([formId, stepDefinitionId])
  @@schema("public")
}

model Campaign {
  id               Int     @id @default(autoincrement())
  structureCodeDna String?
  structureId      Int?
  name             String
  launched         Boolean @default(false)

  structure Structure? @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@schema("public")
}

model Operateur {
  id                Int         @id @default(autoincrement())
  name              String      @unique
  structures        Structure[]
  directionGenerale String?
  siret             String?
  siegeSocial       String?
  cpoms             Cpom[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model Cpom {
  id                  Int                 @id @default(autoincrement())
  name                String?
  structures          CpomStructure[]
  region              Region?             @relation(fields: [regionId], references: [id])
  regionId            Int?
  departements        CpomDepartement[]
  granularity         CpomGranularity     @default(REGIONALE)
  cpomMillesimes      CpomMillesime[]
  operateur           Operateur           @relation(fields: [operateurId], references: [id])
  operateurId         Int
  actesAdministratifs ActeAdministratif[]
  userActions         UserAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model CpomDepartement {
  cpom          Cpom        @relation(fields: [cpomId], references: [id], onDelete: Cascade)
  cpomId        Int
  departement   Departement @relation(fields: [departementId], references: [id], onDelete: Cascade)
  departementId Int

  @@id([cpomId, departementId])
  @@schema("public")
}

enum CpomGranularity {
  DEPARTEMENTALE
  INTERDEPARTEMENTALE
  REGIONALE

  @@schema("public")
}

model CpomStructure {
  id          Int       @id @default(autoincrement())
  cpomId      Int
  structureId Int
  dateStart   DateTime? // Date when the structure joined the CPOM (null = from the beginning of the CPOM)
  dateEnd     DateTime? // Date when the structure left the CPOM (null = until the end of the CPOM)
  cpom        Cpom      @relation(fields: [cpomId], references: [id], onDelete: Cascade)
  structure   Structure @relation(fields: [structureId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([cpomId, structureId])
  @@schema("public")
}

model CpomMillesime {
  id                                Int     @id @default(autoincrement())
  cpomId                            Int
  cpom                              Cpom    @relation(fields: [cpomId], references: [id])
  year                              Int     @default(0)
  dotationDemandee                  Float?
  dotationAccordee                  Float?
  cumulResultatNet                  Float?
  repriseEtat                       Float?
  affectationReservesFondsDedies    Float?
  reserveInvestissement             Float?
  chargesNonReconductibles          Float?
  reserveCompensationDeficits       Float?
  reserveCompensationBFR            Float?
  reserveCompensationAmortissements Float?
  fondsDedies                       Float?
  reportANouveau                    Float?
  autre                             Float?
  commentaire                       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([cpomId, year])
  @@schema("public")
}

model Antenne {
  id          Int       @id @default(autoincrement())
  structure   Structure @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureId Int
  name        String?
  adresse     String?
  codePostal  String?
  commune     String?
  departement String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  @@schema("public")
}

model Finess {
  id          Int       @id @default(autoincrement())
  structure   Structure @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureId Int
  code        String?   @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  @@schema("public")
}

model AllowedUser {
  id                      Int                      @id @default(autoincrement())
  emailPattern            String
  granularity             AllowedUserGranularity
  departementAllowedUsers DepartementAllowedUser[]

  @@schema("public")
}

model DepartementAllowedUser {
  departement   Departement @relation(fields: [departementId], references: [id], onDelete: Cascade)
  departementId Int
  allowedUser   AllowedUser @relation(fields: [allowedUserId], references: [id], onDelete: Cascade)
  allowedUserId Int

  @@id([departementId, allowedUserId])
  @@schema("public")
}

model User {
  id             Int          @id @default(autoincrement())
  prenom         String
  nom            String
  email          String       @unique
  lastConnection DateTime
  userActions    UserAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model UserAction {
  id          Int                @id @default(autoincrement())
  userId      Int
  user        User               @relation(fields: [userId], references: [id])
  action      UserActionCategory
  structure   Structure?         @relation(fields: [structureId], references: [id])
  structureId Int?
  cpom        Cpom?              @relation(fields: [cpomId], references: [id])
  cpomId      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

// Enums
enum Repartition {
  DIFFUS
  COLLECTIF
  MIXTE

  @@schema("public")
}

enum ControleType {
  INOPINE
  PROGRAMME

  @@schema("public")
}

enum PublicType {
  TOUT_PUBLIC
  FAMILLE
  PERSONNES_ISOLEES

  @@schema("public")
}

enum StructureType {
  CADA
  HUDA
  CPH
  CAES
  PRAHDA
  NH

  @@schema("public")
}

// TO DELETE AFTER MIGRATION
enum FileUploadCategory {
  BUDGET_PREVISIONNEL_DEMANDE
  RAPPORT_BUDGETAIRE
  BUDGET_PREVISIONNEL_RETENU
  BUDGET_RECTIFICATIF
  COMPTE_ADMINISTRATIF_SOUMIS
  RAPPORT_ACTIVITE
  COMPTE_ADMINISTRATIF_RETENU
  DEMANDE_SUBVENTION
  COMPTE_RENDU_FINANCIER
  RAPPORT_ACTIVITE_OPERATEUR
  ARRETE_AUTORISATION
  CONVENTION
  ARRETE_TARIFICATION
  CPOM
  INSPECTION_CONTROLE
  EVALUATION
  AUTRE
  AUTRE_FINANCIER

  @@schema("public")
}

enum DocumentFinancierCategory {
  BUDGET_PREVISIONNEL_DEMANDE
  RAPPORT_BUDGETAIRE
  BUDGET_PREVISIONNEL_RETENU
  BUDGET_RECTIFICATIF
  COMPTE_ADMINISTRATIF_SOUMIS
  RAPPORT_ACTIVITE
  COMPTE_ADMINISTRATIF_RETENU
  DEMANDE_SUBVENTION
  COMPTE_RENDU_FINANCIER
  RAPPORT_ACTIVITE_OPERATEUR
  AUTRE_FINANCIER

  @@schema("public")
}

enum ActeAdministratifCategory {
  ARRETE_AUTORISATION
  CONVENTION
  ARRETE_TARIFICATION
  AUTRE
  CPOM // Legacy category (for CPOM documents added before the CPOM form)

  @@schema("public")
}

enum DocumentFinancierGranularity {
  STRUCTURE
  CPOM
  STRUCTURE_ET_CPOM

  @@schema("public")
}

// TO DELETE AFTER MIGRATION
enum FileUploadGranularity {
  STRUCTURE
  CPOM
  STRUCTURE_ET_CPOM

  @@schema("public")
}

enum StepStatus {
  NON_COMMENCE
  COMMENCE
  A_VERIFIER
  FINALISE
  VALIDE

  @@schema("public")
}

enum AllowedUserGranularity {
  DEPARTEMENT
  REGION
  NATIONAL

  @@schema("public")
}

enum UserActionCategory {
  CREATE
  READ
  UPDATE
  DELETE

  @@schema("public")
}

// Views
view ComparaisonPlaces {
  dnaCode                  String?
  total_places_autorisees  Int?
  places_autorisees        Int?
  total_places_activite    Int?
  diff_places              Int?
  diff_places_activite     Int?
  pct_diff_places          Float?
  pct_diff_places_activite Float?

  @@schema("reporting")
}

view StructuresAggregates {
  dnaCode                     String?
  places_autorisees_structure Int?
  pmr_structure               Int?
  lgbt_structure              Int?
  fvv_teh_structure           Int?
  places_autorisees_adresse   Int?
  qpv_adresse                 Int?
  logement_social_adresse     Int?
  date_adresse                DateTime?
  nb_adresses                 Int?
  date_structure              DateTime?
  nb_places_activite          Int?
  diff_places_adresse         Int?
  pct_diff_places_adresse     Float?
  diff_places_activite        Int?
  pct_diff_places_activite    Float?
  created_at                  DateTime?
  updated_at                  DateTime?

  @@schema("reporting")
}

view OperateursAggregates {
  id                          Int
  name                        String
  directionGenerale           String?
  siret                       String?
  siegeSocial                 String?
  nb_structures               Int
  places_autorisees_structure Int?
  pmr_structure               Int?
  lgbt_structure              Int?
  fvv_teh_structure           Int?
  places_autorisees_adresse   Int?
  qpv_adresse                 Int?
  logement_social_adresse     Int?
  created_at                  DateTime?
  updated_at                  DateTime?

  @@schema("reporting")
}

view StructuresFilling {
  dnaCode             String?
  finalisation_status String?
  operateur           String?
  type                String?
  public              String?
  region              String?
  created_at          DateTime?
  updated_at          DateTime?

  @@schema("reporting")
}

view StructuresOrder {
  id                       Int
  codeBhasile              String
  type                     String
  operateur                String?
  finessCode               String?
  nom                      String?
  adresseAdministrative    String
  codePostalAdministratif  String
  communeAdministrative    String
  departementAdministratif String
  region                   String?
  bati                     String?
  placesAutorisees         Int?
  finConvention            DateTime?
  hasForms                 Boolean?

  @@map("structures_order")
  @@schema("public")
}
