model Departement {
  id                   Int                @id @default(autoincrement())
  numero               String             @unique
  name                 String
  population           Int? // Pour le calcul du taux d'équipement (places autorisées / population)
  structures           Structure[]
  structureVersions    StructureVersion[]
  roleDepartements     RoleDepartement[]
  regionAdministrative Region?            @relation(fields: [regionId], references: [id])
  regionId             Int?
  cpoms                CpomDepartement[]
  dnas                 Dna[]

  @@schema("public")
}

model Region {
  id           Int           @id @default(autoincrement())
  name         String
  code         String
  departements Departement[]
  cpoms        Cpom[]

  @@schema("public")
}
