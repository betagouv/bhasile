// TABLES

// Tarifs journaliers cibles par type de structure et zonage (remplissage manuel)
model TarifJournalierCible {
  id             Int           @id @default(autoincrement())
  structure_type StructureType
  belongs_to_idf Boolean
  tarif_cible    Decimal

  @@unique([structure_type, belongs_to_idf])
  @@map("tarif_journalier_cible")
  @@schema("reporting")
}

// Indicateurs globaux d'impact (remplissage manuel)
model GlobalIndicators {
  id Int @id @default(autoincrement())

  budget_annuel              Decimal?
  note_prise_en_main         Float?
  note_clarte_infos          Float?
  note_facilite_utilisation  Float?
  note_robustesse_tech       Float?
  note_remplacement_excel    Float?
  note_gain_temps            Float?
  note_amelioration_pilotage Float?

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("global_indicators")
  @@schema("reporting")
}

// Statistiques mensuelles d'usage (remplissage par cron)
model MonthlyReportingMetric {
  id    Int      @id @default(autoincrement())
  month DateTime @unique

  visits_count             Int
  reads_count              Int
  updates_count            Int
  structures_updated_count Int

  created_at DateTime @default(now())

  @@map("monthly_reporting_metric")
  @@schema("reporting")
}

// Visites par région administrative de la structure consultée (remplissage par cron)
model MonthlyReportingVisitsByRegion {
  id           Int      @id @default(autoincrement())
  month        DateTime
  region_id    Int
  region_name  String
  visits_count Int

  created_at DateTime @default(now())

  @@unique([month, region_id])
  @@map("monthly_reporting_visits_by_region")
  @@schema("reporting")
}

// Statistiques mensuelles de support (remplissage manuel)
model MonthlySupportContact {
  id    Int      @id @default(autoincrement())
  month DateTime @unique

  phone_calls_count Int?
  emails_count      Int?
  notes             String?

  created_at DateTime @default(now())

  @@map("monthly_support_contact")
  @@schema("reporting")
}

// Statistiques mensuelles de qualité des structures (remplissage par cron)
model MonthlyStructuresGlobalQualityCount {
  id    Int      @id @default(autoincrement())
  month DateTime @unique

  structures_count Int
  indicators_count Int
  issues_count_sum Int

  // Agrégats par catégorie (somme des décomptes par indicateur du mois)
  indicateurs_utiles_count Int?
  indicateurs_impact_count Int?

  has_issue_authorisation_period_not_15y                         Int?
  has_issue_authorized_convention_not_5y                         Int?
  has_issue_authorized_convention_outside_authorisation_period   Int?
  has_issue_authorized_convention_missing_or_expired             Int?
  has_issue_convention_dates_differ_from_actes_administratifs    Int?
  has_issue_authorisation_dates_differ_from_actes_administratifs Int?
  has_issue_evaluation_not_done_in_time                          Int?
  has_issue_subsidized_convention_gt_3y                          Int?
  has_issue_specific_places_gt_places_autorisees                 Int?
  has_issue_incoherence_lgbt_places                              Int?
  has_issue_incoherence_fvvteh_places                            Int?
  has_issue_places_structure_vs_address_diff_gt_10pct            Int?
  has_issue_dept_code                                            Int?
  has_issue_multi_dna                                            Int?
  has_issue_cpom_mono_structure                                  Int?
  has_issue_taux_encadrement_max_gt_threshold                    Int?
  has_issue_taux_encadrement_min_lt_2                            Int?
  has_issue_cout_journalier_max_gt_tarif_cible                   Int?
  has_issue_missing_convention_document                          Int?
  has_issue_missing_autorisation_document                        Int?
  has_issue_missing_cpom_document                                Int?
  has_issue_places_indisponibles_gt_3pct                         Int?
  has_issue_presences_indues_gt_7pct                             Int?
  has_issue_cout_journalier_min_lt_15                            Int?
  has_issue_resultat_net_eq_0                                    Int?
  has_issue_authorized_affectations_breakdown_missing            Int?
  has_issue_authorized_affectations_breakdown_mismatch           Int?
  has_issue_authorized_reprise_plus_affectations_mismatch        Int?
  has_issue_authorized_reprise_wrong_sign                        Int?
  has_issue_subsidized_deficit_nonzero_boxes                     Int?
  has_issue_subsidized_excedent_reprise_etat_nonzero             Int?
  has_issue_subsidized_excedent_rules                            Int?

  created_at DateTime @default(now())

  @@map("monthly_structures_global_quality_count")
  @@schema("reporting")
}

// VIEWS
view ReportingGlobal {
  id Int

  global_indicators_updated_at DateTime?
  budget_annuel                Decimal?

  places_suivies_total          Int
  dotation_structures_hors_cpom Decimal?
  dotation_cpoms                Decimal?
  dotation_parc_total           Decimal?

  updates_count_total          Int
  indicateurs_utiles_count_max Int
  indicateurs_impact_count_max Int

  note_facilite_utilisation_moyenne_4_criteres Float?
  note_remplacement_excel                      Float?
  note_gain_temps                              Float?
  note_amelioration_pilotage                   Float?

  first_update_at        DateTime?
  budget_depense_prorata Decimal?

  cout_par_mise_a_jour      Decimal?
  cout_par_situation_utile  Decimal?
  cout_par_detection_impact Decimal?

  @@unique([id])
  @@map("reporting_global")
  @@schema("reporting")
}

view ReportingMensuel {
  month DateTime @unique

  visits_count                    Int
  phone_calls_count               Int?
  emails_count                    Int?
  score_besoin_support_pour_mille Decimal?
  updates_count                   Int
  indicateurs_utiles_count        Int
  indicateurs_impact_count        Int

  @@map("reporting_mensuel")
  @@schema("reporting")
}

