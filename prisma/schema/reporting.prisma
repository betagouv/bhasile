view StructuresMissingHistory {
  id                       Int
  codeBhasile              String  @map("code_bhasile")
  operateur                String?
  departementAdministratif String? @map("departement_administratif")
  departement              String?
  region                   String?
  dna_codes                String?

  has_missing_acte_administratif   Boolean
  has_missing_budget               Boolean
  has_missing_document_financier   Boolean
  has_missing_indicateur_financier Boolean
  has_any_missing                  Boolean

  @@unique([id])
  @@map("structures_missing_history")
  @@schema("reporting")
}
