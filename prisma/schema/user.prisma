model User {
  id             Int           @id @default(autoincrement())
  name           String?
  email          String        @unique
  lastConnection DateTime
  userActions    UserAction[]
  role           Role?         @relation(fields: [roleId], references: [id])
  roleId         Int?
  emailPattern   EmailPattern? @relation(fields: [emailPatternId], references: [id])
  emailPatternId Int?
  notes          Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model UserAction {
  id          Int                @id @default(autoincrement())
  userId      Int
  user        User               @relation(fields: [userId], references: [id])
  action      UserActionCategory
  structure   Structure?         @relation(fields: [structureId], references: [id])
  structureId Int?
  cpom        Cpom?              @relation(fields: [cpomId], references: [id])
  cpomId      Int?
  operateur   Operateur?         @relation(fields: [operateurId], references: [id])
  operateurId Int?

  createdAt DateTime @default(now())

  @@schema("public")
}

model Role {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  roleDepartements RoleDepartement[]
  users            User[]
  emailPatterns    EmailPattern[]

  @@schema("public")
}

model RoleDepartement {
  departement   Departement @relation(fields: [departementId], references: [id], onDelete: Cascade)
  departementId Int
  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId        Int

  @@id([departementId, roleId])
  @@schema("public")
}

model EmailPattern {
  id      Int    @id @default(autoincrement())
  pattern String @unique
  role    Role   @relation(fields: [roleId], references: [id])
  roleId  Int
  users   User[]

  @@schema("public")
}

enum UserActionCategory {
  CREATE
  READ
  UPDATE
  DELETE

  @@schema("public")
}
