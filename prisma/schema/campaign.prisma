model Campaign {
  id                   Int                 @id @default(autoincrement())
  name                 String? // TODO: redondant avec campaignDefinition.name — drop après grep des lecteurs
  campaignDefinitionId Int? // TODO: rendre obligatoire après backfill (one-off 20260703-create-campaign-definitions)
  campaignDefinition   CampaignDefinition? @relation(fields: [campaignDefinitionId], references: [id])

  form             Form?
  structureVersion StructureVersion?

  @@schema("public")
}

model CampaignDefinition {
  id      Int    @id @default(autoincrement())
  name    String
  version Int
  slug    String @unique

  campaigns Campaign[]

  @@schema("public")
}
