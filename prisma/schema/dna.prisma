model Dna {
  id                           Int                         @id @default(autoincrement())
  code                         String                      @unique
  description                  String?
  activeInOfiiFileSince        DateTime? // date d'entrée dans le document Ofii
  inactiveInOfiiFileSince      DateTime? // date de sortie du document Ofii
  dnaStructures                DnaStructure[]
  activites                    Activite[]
  evenementsIndesirablesGraves EvenementIndesirableGrave[]

  // All fields below are directly coming from OFII file and not used after DNA is linked to a structure
  departement              Departement?   @relation(fields: [departementAdministratif], references: [numero])
  departementAdministratif String? // TODO: remove nullable after first filling is complete
  operateur                Operateur?     @relation(fields: [operateurId], references: [id])
  operateurId              Int? // TODO: remove nullable after first filling is complete
  type                     StructureType? // TODO: remove nullable after first filling is complete
  nom                      String? // TODO: remove nullable after first filling is complete
  nomOfii                  String? // TODO: remove nullable after first filling is complete
  directionTerritoriale    String? // TODO: remove nullable after first filling is complete

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model DnaStructure {
  id                        Int                      @id @default(autoincrement())
  dnaId                     Int
  dna                       Dna                      @relation(fields: [dnaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureId               Int?
  structure                 Structure?               @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  transformationStructure   TransformationStructure? @relation(fields: [transformationStructureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  transformationStructureId Int?
  startDate                 DateTime? // Empty by default, set when a DNA changes its structure
  endDate                   DateTime? // Empty by default, set when a DNA changes its structure

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model Antenne {
  id          Int       @id @default(autoincrement())
  structure   Structure @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureId Int
  name        String?
  adresse     String?
  codePostal  String?
  commune     String?
  departement String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  @@schema("public")
}

model Finess {
  id                        Int                      @id @default(autoincrement())
  structure                 Structure?               @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureId               Int?
  transformationStructure   TransformationStructure? @relation(fields: [transformationStructureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  transformationStructureId Int?
  code                      String?                  @unique
  description               String?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @default(now()) @updatedAt

  @@schema("public")
}
