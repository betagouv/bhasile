// Phase 1 (hors transfo) : StructureVersion + FK optionnelles pour backfill.
// TODO: retirer les liens à structureId après backfill, et rendre structureVersionId obligatoire sur les tables liées
// Retirer les FK / scalaires redondants sur Structure.

model StructureVersion {
  id          Int        @id @default(autoincrement())
  structureId Int?
  structure   Structure? @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  structureVersionTransformationId Int?                            @unique
  structureVersionTransformation   StructureVersionTransformation? @relation(fields: [structureVersionTransformationId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  campaignId Int?      @unique
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  effectiveDate DateTime?

  adresseAdministrative    String?
  codePostalAdministratif  String?
  communeAdministrative    String?
  departementAdministratif String?
  latitude                 Decimal?
  longitude                Decimal?
  nom                      String?
  creationDate             DateTime? // TODO: drop — immutable, remis sur Structure
  date303                  DateTime? // TODO: drop — immutable, remis sur Structure
  lgbt                     Boolean? // TODO: remove after quality check
  fvvTeh                   Boolean? // TODO: remove after quality check
  public                   PublicType?
  notes                    String?
  nomOfii                  String?
  directionTerritoriale    String?

  departement Departement? @relation(fields: [departementAdministratif], references: [numero])

  contacts            Contact[]
  adresses            Adresse[]
  structureTypologies StructureTypologie[]
  antennes            Antenne[]
  structureFinesses   StructureFiness[]
  finesses            Finess[] // TODO: remove after backfill structure finess
  dnaStructures       DnaStructure[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([structureId, effectiveDate])
  @@schema("public")
}
