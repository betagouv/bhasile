model Controle {
  id          Int          @id @default(autoincrement())
  structure   Structure?   @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureId Int?
  date        DateTime
  type        ControleType
  fileUploads FileUpload[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

enum ControleType {
  INOPINE
  PROGRAMME

  @@schema("public")
}
