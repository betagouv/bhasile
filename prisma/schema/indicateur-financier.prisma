model IndicateurFinancier {
  id                                Int        @id @default(autoincrement())
  structure                         Structure? @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureId                       Int?
  year                              Int        @default(0)
  type                              IndicateurFinancierType
  ETP                               Float?
  tauxEncadrement                   Float?
  coutJournalier                    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([structureId, year, type])

  @@schema("public")
}

enum IndicateurFinancierType {
  PREVISIONNEL
  REALISE

  @@schema("public")
}
