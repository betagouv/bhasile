model Transformation {
  id                       Int                         @id @default(autoincrement())
  date                     DateTime?
  etat                     TransformationEtat          @default(EN_COURS)
  structures               StructureTransformation[]
  transformationStructures TransformationStructure[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model StructureTransformation {
  id               Int            @id @default(autoincrement())
  transformationId Int
  transformation   Transformation @relation(fields: [transformationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureId      Int
  structure        Structure      @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([transformationId, structureId])
  @@schema("public")
}

model TransformationStructure {
  id                       Int                 @id @default(autoincrement())
  transformationId         Int
  transformation           Transformation      @relation(fields: [transformationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  transformationType       TransformationType?
  transformationDate       DateTime?
  codeBhasile              String?
  filiale                  String?
  type                     StructureType?
  adresseAdministrative    String?
  codePostalAdministratif  String?
  communeAdministrative    String?
  departementAdministratif String?
  latitude                 Decimal?
  longitude                Decimal?
  nom                      String?
  debutConvention          DateTime?
  finConvention            DateTime?
  creationDate             DateTime?
  date303                  DateTime?
  lgbt                     Boolean?
  fvvTeh                   Boolean?
  public                   PublicType?
  debutPeriodeAutorisation DateTime?
  finPeriodeAutorisation   DateTime?
  notes                    String?
  nomOfii                  String?
  directionTerritoriale    String?
  dnaStructures            DnaStructure[]
  adresses                 Adresse[]
  contacts                 Contact[]
  actesAdministratifs      ActeAdministratif[]
  finesses                 Finess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

enum TransformationEtat {
  EN_COURS
  FINALISEE
  ANNULEE

  @@schema("public")
}

enum TransformationType {
  CREATION
  EXTENSION
  CONTRACTION
  FERMETURE

  @@schema("public")
}
