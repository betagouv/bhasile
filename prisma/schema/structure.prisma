model Structure {
  id                       Int                   @id @default(autoincrement())
  codeBhasile              String                @unique
  filiale                  String? // TODO: remove after first filling is complete, filiales via Operateur are connected in app and DB is backfilled
  // TODO: remove after backfill of structure version — champs migrés sur StructureVersion
  type                     StructureType? // TODO: remove after backfill of structure version
  adresseAdministrative    String? // TODO: remove after backfill of structure version
  codePostalAdministratif  String? // TODO: remove after backfill of structure version
  communeAdministrative    String? // TODO: remove after backfill of structure version
  departementAdministratif String? // Conservé : invariant immuable du département, source de vérité de checkNoDepartementAdministratifChange (ne pas retirer au backfill)
  latitude                 Decimal? // TODO: remove after backfill of structure version
  longitude                Decimal? // TODO: remove after backfill of structure version
  nom                      String? // TODO: remove after backfill of structure version
  debutConvention          DateTime? // TODO: remove after quality check
  finConvention            DateTime? // TODO: remove after quality check
  creationDate             DateTime?
  fermetureDate            DateTime?
  date303                  DateTime?
  lgbt                     Boolean? // TODO: remove after backfill of structure version
  fvvTeh                   Boolean? // TODO: remove after backfill of structure version
  public                   PublicType? // TODO: remove after backfill of structure version
  debutPeriodeAutorisation DateTime? // TODO: remove after quality check
  finPeriodeAutorisation   DateTime? // TODO: remove after quality check
  notes                    String? // TODO: remove after backfill of structure version
  nomOfii                  String? // TODO: remove after backfill of structure version
  directionTerritoriale    String? // TODO: remove after backfill of structure version
  dnaStructures            DnaStructure[] // TODO: remove after backfill of structure version
  controles                Controle[]
  evaluations              Evaluation[]
  adresses                 Adresse[] // TODO: remove after backfill of structure version
  contacts                 Contact[] // TODO: remove after backfill of structure version
  structureTypologies      StructureTypologie[] // TODO: remove after backfill of structure version
  actesAdministratifs      ActeAdministratif[]
  documentsFinanciers      DocumentFinancier[]
  cpomStructures           CpomStructure[]
  structureMillesimes      StructureMillesime[]
  budgets                  Budget[] // TODO: remove after backfill of structure version — via StructureMillesime uniquement
  indicateursFinanciers    IndicateurFinancier[] // TODO: remove after backfill of structure version
  operateur                Operateur?            @relation(fields: [operateurId], references: [id])
  operateurId              Int?
  forms                    Form[]
  antennes                 Antenne[] // TODO: remove after backfill of structure version
  structureFinesses        StructureFiness[] // TODO: remove after backfill of structure version
  finesses                 Finess[] // TODO: remove after backfill structure finess
  departement              Departement?          @relation(fields: [departementAdministratif], references: [numero]) // Conservé avec departementAdministratif (cf. ci-dessus)
  userActions              UserAction[]
  userNotes                Note[]
  structureVersions        StructureVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model StructureMillesime {
  id               Int        @id @default(autoincrement())
  structure        Structure? @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureId      Int?
  year             Int
  cpom             Boolean    @default(false) // temporary field, while we are not sure of existing cpoms
  operateurComment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([structureId, year])
  @@schema("public")
}

model StructureTypologie {
  id                    Int               @id @default(autoincrement())
  structure             Structure?        @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade) // TODO: remove after backfill of structure version
  structureId           Int? // TODO: remove after backfill of structure version
  structureVersion      StructureVersion? @relation(fields: [structureVersionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureVersionId    Int? // TODO: rendre obligatoire après backfill de structure version
  year                  Int
  placesAutorisees      Int?
  pmr                   Int?
  lgbt                  Int?
  fvvTeh                Int?
  placesACreer          Int? // TODO: remove after quality check
  placesAFermer         Int? // TODO: remove after quality check
  echeancePlacesACreer  DateTime? // TODO: remove after quality check
  echeancePlacesAFermer DateTime? // TODO: remove after quality check

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([structureId, year]) // TODO: remove after backfill of structure version
  @@unique([structureVersionId, year])
  @@schema("public")
}

enum PublicType {
  TOUT_PUBLIC
  FAMILLE
  PERSONNES_ISOLEES

  @@schema("public")
}

enum StructureType {
  CADA
  HUDA
  CPH
  CAES
  PRAHDA
  NH

  @@schema("public")
}

view StructuresAggregates {
  id                          Int       @unique
  code_bhasile                String?
  dna_codes                   String?
  departement_administratif   String?
  departement                 String?
  region                      String?
  operateur                   String?
  structure_type              String?
  public                      String?
  latitude                    Decimal?
  longitude                   Decimal?
  updated_at                  DateTime?
  finalisation_status         String?
  finalisation_status_detail  String?
  places_autorisees_structure Int?
  dotation_derniere_annee     Float?

  @@map("structures_aggregates")
  @@schema("reporting")
}

view StructuresFilling {
  id                         Int       @unique
  code_bhasile               String?
  finalisation_status        String?
  finalisation_status_detail String?
  operateur                  String?
  structure_type             String?
  public                     String?
  region                     String?
  created_at                 DateTime?
  updated_at                 DateTime?

  @@map("structures_filling")
  @@schema("reporting")
}
