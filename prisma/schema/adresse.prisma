model Adresse {
  id                 Int                @id @default(autoincrement())
  structure          Structure?         @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade) // TODO: remove after backfill of structure version
  structureId        Int? // TODO: remove after backfill of structure version
  structureVersion   StructureVersion?  @relation(fields: [structureVersionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureVersionId Int? // TODO: rendre obligatoire après backfill de structure version
  adresse            String?
  codePostal         String?
  commune            String?
  repartition        Repartition?
  placesAutorisees   Int?
  qpv                Int?
  logementSocial     Int?
  adresseTypologies  AdresseTypologie[] // TODO: remove after migration

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

// TODO: remove model after migration 
model AdresseTypologie {
  id               Int     @id @default(autoincrement())
  adresse          Adresse @relation(fields: [adresseId], references: [id], onDelete: Cascade)
  adresseId        Int
  placesAutorisees Int
  year             Int
  qpv              Int
  logementSocial   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([adresseId, year])
  @@schema("public")
}

enum Repartition {
  DIFFUS
  COLLECTIF
  MIXTE

  @@schema("public")
}
