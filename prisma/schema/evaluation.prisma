model Evaluation {
  id            Int          @id @default(autoincrement())
  structure     Structure?   @relation(fields: [structureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structureId   Int?
  date          DateTime?
  notePersonne  Float?
  notePro       Float?
  noteStructure Float?
  note          Float?
  fileUploads   FileUpload[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}
