model Operateur {
  id                              Int                              @id @default(autoincrement())
  name                            String                           @unique
  structures                      Structure[]
  structureVersionTransformations StructureVersionTransformation[]
  directionGenerale               String?
  siret                           String?
  siegeSocial                     String?
  parent                          Operateur?                       @relation("OperateurToOperateur", fields: [parentId], references: [id])
  parentId                        Int?
  cpoms                           Cpom[]
  filiales                        Operateur[]                      @relation("OperateurToOperateur")
  userActions                     UserAction[]
  dnas                            Dna[]
  actesAdministratifs             ActeAdministratif[]
  contacts                        Contact[]
  logo                            FileUpload?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

view OperateursAggregates {
  id                          Int
  name                        String
  direction_generale          String?
  siege_social                String?
  siret                       String?
  nb_structures               Int
  places_autorisees_structure Int?
  created_at                  DateTime?
  updated_at                  DateTime?

  @@map("operateurs_aggregates")
  @@schema("reporting")
}
